{
  "name": "@media-auth/api",
  "version": "1.0.0",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:migrate": "node src/db/migrate.js",
    "migrate:s3-scan-keys": "node src/scripts/migrate-s3-scan-keys-to-structured-layout.js",
    "test": "node --test test/*.test.js",
    "test:integration:api": "RUN_API_INTEGRATION=1 node --test --test-concurrency=1 test/integration/*.integration.test.js",
    "test:integration:api:s3": "RUN_API_INTEGRATION=1 RUN_API_INTEGRATION_WORKER=1 RUN_API_S3_STORAGE_INTEGRATION=1 node --test --test-concurrency=1 test/integration/scanApiS3Storage.minio-integration.test.js"
  },
  "dependencies": {
    "@media-auth/scan-storage": "file:../../packages/scan-storage",
    "@media-auth/worker": "file:../worker",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.10.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
