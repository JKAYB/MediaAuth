# Local dev
VITE_API_BASE_URL=http://localhost:4000

# Optional: enables the internal scan ops UI at /internal/scans (must match API INTERNAL_OPS_TOKEN).
# Vite inlines this at build time — use only on trusted machines / private deploys, never commit real secrets.
# VITE_INTERNAL_OPS_TOKEN=

# Production (Netlify, etc.): set the same variable in the host UI so Vite
# bakes it in at build time. Use your public API origin, e.g.:
# VITE_API_BASE_URL=https://api.yourdomain.com
#
# Your API must allow the web origin in CORS (see apps/api CORS_ORIGIN).
