# Example environment for local development when using `docker-compose.yml`
# (Postgres + Redis + MinIO on localhost). Copy values into repo root `.env`
# (API and worker load `../../../.env` from their `src/`).
#
# This file is tracked in git. Do not put production secrets here.

# --- Postgres (Compose service `postgres`, host port 5432) ---
DATABASE_URL=postgresql://mediaauth:mediaauth@127.0.0.1:5432/mediaauth

# --- Redis (Compose service `redis`, host port 6379) ---
REDIS_URL=redis://127.0.0.1:6379

# --- API / auth ---
JWT_SECRET=dev-only-change-me
PORT=4000

# --- Detection (local dev) ---
DETECTION_PROVIDER=mock

# --- Object storage: use MinIO from Compose (host reaches API at localhost:9000) ---
# For disk-only uploads instead, use: OBJECT_STORAGE_PROVIDER=local and omit bucket vars.
OBJECT_STORAGE_PROVIDER=s3
OBJECT_STORAGE_BUCKET=media-auth-dev
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_ACCESS_KEY_ID=minio
OBJECT_STORAGE_SECRET_ACCESS_KEY=minio12345
OBJECT_STORAGE_FORCE_PATH_STYLE=1
# OBJECT_STORAGE_PREFIX=

# --- Internal ops (optional) ---
# INTERNAL_OPS_TOKEN=dev-internal-token

# --- Web (Vite): set in apps/web/.env or export before `npm run dev:web` ---
# VITE_API_BASE_URL=http://localhost:4000
# VITE_INTERNAL_OPS_TOKEN must match INTERNAL_OPS_TOKEN if you use the ops UI; it is baked into the client bundle at dev start.
